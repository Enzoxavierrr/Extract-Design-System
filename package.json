{
  "name": "agent-design-system",
  "version": "1.0.0",
  "description": "Automated design token extractor from websites",
  "main": "src/server.js",
  "bin": {
    "extract-tokens": "./bin/extract-tokens.js"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "npx browser-sync start --proxy 'localhost:3000' --files 'public/**/*' --no-open & node src/server.js",
    "dev:live": "npx browser-sync start --server 'public' --files 'public/**/*' --no-open",
    "extract": "node ./bin/extract-tokens.js",
    "postinstall": "playwright install",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "playwright": "^1.55.0"
  },
  "devDependencies": {
    "browser-sync": "^3.0.4"
  }
}
